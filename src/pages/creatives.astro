---
import BaseLayout from "../layouts/BaseLayout.astro";
import Headline from "../components/ui/Headline.astro";
import { Icon } from "astro-icon/components";

const metadata = {
  title: "Creatives",
  description:
    "Poems, photography notes, and design experiments — the softer edges around the engineering work.",
};

const creativeSections = [
  {
    title: "Photography",
    description:
      "Visual notes from the field — light, texture, and the quiet moments around industrial spaces.",
    href: "/creatives/photography",
    icon: "lucide:camera",
    iconClass: "bg-sky-500/10 text-sky-600 dark:text-sky-400",
  },
  {
    title: "Poetry",
    description:
      "Short poems and fragments — the kind that don’t fit in a deck but stick in the mind.",
    href: "/creatives/poetry",
    icon: "lucide:flower-2",
    iconClass: "bg-rose-500/10 text-rose-600 dark:text-rose-400",
  },
  {
    title: "Design",
    description:
      "Slide grammar, visual storytelling, and experiments in explaining complex systems simply.",
    href: "/creatives/design",
    icon: "lucide:palette",
    iconClass: "bg-violet-500/10 text-violet-600 dark:text-violet-400",
  },
];
---

<BaseLayout {metadata} section="Creatives">
  <section class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-5xl space-y-10">
      <Headline
        tagline="Creatives"
        title="The quieter side of the work"
        subtitle="Pieces that don’t fit neatly into a resume: poems, visual notes, and design experiments."
        classes={{
          container: "mb-8 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "max-w-3xl text-base text-muted-foreground",
        }}
      />

      <div class="grid gap-6 sm:grid-cols-3">
        {creativeSections.map((item) => (
          <a
            href={item.href}
            class="group flex flex-col rounded-2xl border border-border bg-card/60 p-5 transition-colors hover:border-primary/50 hover:bg-card"
          >
            <div
              class={`mb-4 flex h-14 w-14 items-center justify-center rounded-xl ${item.iconClass}`}
            >
              <Icon name={item.icon} class="h-7 w-7" />
            </div>
            <h2 class="text-lg font-semibold text-foreground group-hover:text-primary">
              {item.title}
            </h2>
            <p class="mt-1 flex-1 text-sm text-muted-foreground">
              {item.description}
            </p>
            <span class="mt-3 inline-flex items-center text-sm font-medium text-primary">
              View {item.title}
              <span class="ml-1 transition-transform group-hover:translate-x-0.5"
                >→</span
              >
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

