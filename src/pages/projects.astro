---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Headline from "../components/ui/Headline.astro";

const projects = await getCollection("projects");

const metadata = {
  title: "Projects",
  description:
    "Selected projects exploring AI systems for industrial monitoring, energy-aware operations, and real-world deployments.",
};
---

<BaseLayout {metadata} section="Projects">
  <section class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-5xl">
      <Headline
        tagline="Projects"
        title="Where ideas met reality"
        subtitle="A small set of projects around industrial AI, time-series modeling, and systems thinking. Most entries are stubs I’ll fill in over time."
        classes={{
          container: "mb-10 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "max-w-3xl text-base text-muted-foreground",
        }}
      />

      <div class="space-y-6">
        {projects.map((project) => {
          const slug = project.slug ?? project.id;
          return (
            <article class="reveal rounded-2xl border border-border bg-card/60 p-6 hover:border-primary/50 transition-colors">
              <h2 class="text-lg font-semibold text-foreground">
                {project.data.title}
              </h2>
              {project.data.description && (
                <p class="mt-1 text-sm text-muted-foreground">
                  {project.data.description}
                </p>
              )}
              <div class="mt-2 flex flex-wrap gap-2 text-xs text-muted-foreground">
                {project.data.status && (
                  <span class="rounded-full bg-foreground/5 px-3 py-1">
                    {project.data.status}
                  </span>
                )}
                {Array.isArray(project.data.tags) &&
                  project.data.tags.map((tag) => (
                    <span class="rounded-full bg-foreground/5 px-3 py-1">
                      {tag}
                    </span>
                  ))}
              </div>
              <a
                href={`/projects/${slug}`}
                class="mt-4 inline-flex text-xs font-semibold text-primary hover:underline"
              >
                Read more
              </a>
            </article>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

