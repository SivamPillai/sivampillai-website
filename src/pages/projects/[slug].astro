---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import RelatedContent from "../../components/thinking/RelatedContent.astro";
import { getStorageImageUrl } from "../../utils/storage";

type ProjectEntry = CollectionEntry<"projects">;

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => {
    const slug = (project as { id: string; slug?: string }).slug ?? project.id;
    return {
      params: { slug },
      props: { project },
    };
  });
}

const { project } = Astro.props as { project: ProjectEntry };
const { Content, remarkPluginFrontmatter } = await render(project);
const { title, description, subtitle, pubDate, image, author } =
  project.data;
const imageUrl = getStorageImageUrl(image);

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const readingTime = remarkPluginFrontmatter?.minutesRead
  ? `${Math.ceil(remarkPluginFrontmatter.minutesRead)} minutes read`
  : "";

const metadata = {
  title: project.data.title,
  description: project.data.description,
  ogImage: imageUrl,
};
---

<BaseLayout {metadata} section="Projects">
  <section class="relative px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="relative mx-auto max-w-3xl">
      <div class="reveal mb-10 text-left">
        <p class="text-sm font-semibold tracking-wide text-primary uppercase">
          {formattedDate}
          {author && ` • ${author}`}
          {readingTime && ` • ${readingTime}`}
        </p>
        <h1
          class="font-heading mt-2 text-3xl font-bold leading-tight tracking-tighter text-foreground sm:text-4xl md:text-5xl"
        >
          {title}
        </h1>
        {subtitle && (
          <p class="mt-2 text-lg text-muted-foreground">{subtitle}</p>
        )}
      </div>

      {imageUrl && (
        <div class="reveal relative mb-8 h-96 w-full overflow-hidden rounded-xl shadow-lg">
          <img src={imageUrl} alt={title} class="h-full w-full object-cover" />
        </div>
      )}

      <div class="mb-4 flex flex-wrap gap-2 text-xs text-muted-foreground">
        {project.data.status && (
          <span class="rounded-full bg-foreground/5 px-3 py-1">
            {project.data.status}
          </span>
        )}
        {Array.isArray(project.data.tags) &&
          project.data.tags.map((tag) => (
            <span class="rounded-full bg-foreground/5 px-3 py-1">{tag}</span>
          ))}
      </div>

      <div
        class="prose prose-lg dark:prose-invert mx-auto prose-headings:text-foreground prose-a:text-primary hover:prose-a:underline prose-p:text-muted-foreground prose-strong:text-foreground prose-li:text-muted-foreground prose-code:text-primary"
      >
        <Content />
      </div>

      <RelatedContent currentId={project.id} tags={project.data.tags} />
    </div>
  </section>
</BaseLayout>
