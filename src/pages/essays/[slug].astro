---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import Headline from "../../components/ui/Headline.astro";
import RelatedContent from "../../components/thinking/RelatedContent.astro";
import { getStorageImageUrl } from "../../utils/storage";

type EssayEntry = CollectionEntry<"essays">;

export async function getStaticPaths() {
  const essays = await getCollection("essays");
  return essays.map((essay) => {
    const slug = (essay as { id: string; slug?: string }).slug ?? essay.id;
    return {
      params: { slug },
      props: { essay },
    };
  });
}

const { essay } = Astro.props as { essay: EssayEntry };
const { Content } = await render(essay);
const { title, description, pubDate, tags, image } = essay.data;
const imageUrl = getStorageImageUrl(image);

const metadata = {
  title,
  description: description ?? title,
  ogImage: imageUrl,
};
---

<BaseLayout {metadata} section="Essays">
  <article class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-3xl">
      <Headline
        tagline="Essay"
        title={title}
        subtitle={description ?? undefined}
        classes={{
          container: "mb-6 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "max-w-2xl text-base text-muted-foreground",
        }}
      />

      <div class="mb-4 flex flex-wrap gap-2 text-xs text-muted-foreground">
        <span>
          {pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })}
        </span>
        {Array.isArray(tags) &&
          tags.map((tag) => (
            <span class="rounded-full bg-foreground/5 px-3 py-1">{tag}</span>
          ))}
      </div>

      {imageUrl && (
        <div class="reveal relative mb-8 h-72 w-full overflow-hidden rounded-xl border border-border shadow-md sm:h-96">
          <img
            src={imageUrl}
            alt={title}
            class="h-full w-full object-cover"
          />
        </div>
      )}

      <div class="prose prose-invert max-w-none text-sm leading-relaxed">
        <Content />
      </div>

      <RelatedContent currentId={essay.id} tags={tags ?? []} />
    </div>
  </article>
</BaseLayout>
