---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import RelatedContent from "../../components/thinking/RelatedContent.astro";
import { getStorageImageUrl } from "../../utils/storage";

type EssayEntry = CollectionEntry<"essays">;

export async function getStaticPaths() {
  const essays = await getCollection("essays");
  return essays.map((essay) => {
    const slug = (essay as { id: string; slug?: string }).slug ?? essay.id;
    return {
      params: { slug },
      props: { essay },
    };
  });
}

const { essay } = Astro.props as { essay: EssayEntry };
const { Content, remarkPluginFrontmatter } = await render(essay);
const { title, description, subtitle, pubDate, tags, image, author } =
  essay.data;
const imageUrl = getStorageImageUrl(image);

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const readingTime = remarkPluginFrontmatter?.minutesRead
  ? `${Math.ceil(remarkPluginFrontmatter.minutesRead)} minutes read`
  : "";

const metadata = {
  title,
  description: description ?? title,
  ogImage: imageUrl,
};
---

<BaseLayout {metadata} section="Essays">
  <section class="relative px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="relative mx-auto max-w-3xl">
      <div class="reveal mb-10 text-left">
        <p class="text-sm font-semibold tracking-wide text-primary uppercase">
          {formattedDate}
          {author && ` • ${author}`}
          {readingTime && ` • ${readingTime}`}
        </p>
        <h1
          class="font-heading mt-2 text-3xl font-bold leading-tight tracking-tighter text-foreground sm:text-4xl md:text-5xl"
        >
          {title}
        </h1>
        {subtitle && (
          <p class="mt-2 text-lg text-muted-foreground">{subtitle}</p>
        )}
      </div>

      {imageUrl && (
        <div class="reveal relative mb-8 h-96 w-full overflow-hidden rounded-xl shadow-lg">
          <img src={imageUrl} alt={title} class="h-full w-full object-cover" />
        </div>
      )}

      <div class="mb-4 flex flex-wrap gap-2 text-xs text-muted-foreground">
        {Array.isArray(tags) &&
          tags.map((tag) => (
            <span class="rounded-full bg-foreground/5 px-3 py-1">{tag}</span>
          ))}
      </div>

      <div
        class="reveal prose prose-lg dark:prose-invert mx-auto prose-headings:text-foreground prose-a:text-primary hover:prose-a:underline prose-p:text-muted-foreground prose-strong:text-foreground prose-li:text-muted-foreground prose-code:text-primary"
      >
        <Content />
      </div>

      <RelatedContent currentId={essay.id} tags={tags ?? []} />
    </div>
  </section>
</BaseLayout>
