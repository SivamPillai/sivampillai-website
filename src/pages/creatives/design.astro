---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Headline from "../../components/ui/Headline.astro";

const design = (await getCollection("design")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const metadata = {
  title: "Design",
  description:
    "Slide grammar, visual storytelling, and experiments in explaining complex systems simply.",
};
---

<BaseLayout {metadata} section="Design">
  <section class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-5xl">
      <Headline
        tagline="Design"
        title="Visual storytelling"
        subtitle="Slide grammar and experiments in explaining complex systems simply."
        classes={{
          container: "mb-8 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "text-base text-muted-foreground",
        }}
      />

      <nav class="mb-6 text-sm">
        <a href="/creatives" class="text-muted-foreground hover:text-primary"
          >← Creatives</a
        >
      </nav>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          design.map((entry) => (
            <article class="group flex flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/5">
              <div class="relative aspect-video w-full overflow-hidden bg-muted/30">
                {entry.data.image ? (
                  <img
                    src={entry.data.image}
                    alt={entry.data.title}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                ) : (
                  <div
                    class="flex h-full w-full items-center justify-center text-muted-foreground"
                    aria-hidden="true"
                  >
                    <span class="text-sm">No image</span>
                  </div>
                )}
              </div>
              <div class="flex flex-1 flex-col p-4">
                <h2 class="text-lg font-semibold text-foreground">
                  {entry.data.title}
                </h2>
                {entry.data.description && (
                  <p class="mt-2 flex-1 text-sm text-muted-foreground line-clamp-3">
                    {entry.data.description}
                  </p>
                )}
                <p class="mt-3 text-xs text-muted-foreground">
                  {entry.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
