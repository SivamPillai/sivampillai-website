---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Headline from "../components/ui/Headline.astro";

const essays = (await getCollection("essays")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const metadata = {
  title: "Essays",
  description:
    "Longer-form thinking on AI systems, manufacturing, and how ideas travel from notebooks into deployed products.",
};
---

<BaseLayout {metadata} section="Essays">
  <section class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-5xl">
      <Headline
        tagline="Essays"
        title="Thinking out loud"
        subtitle="Essays and longer notes. Many will start life as rough drafts and sharpen over time."
        classes={{
          container: "mb-10 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "max-w-3xl text-base text-muted-foreground",
        }}
      />

      <div class="space-y-6">
        {
          essays.map((essay) => {
            const slug =
              (essay as { id: string; slug?: string }).slug ?? essay.id;
            return (
              <article class="reveal rounded-2xl border border-border bg-card/60 p-5 hover:border-primary/50 transition-colors">
                <h2 class="text-lg font-semibold text-foreground">
                  {essay.data.title}
                </h2>
                {essay.data.description && (
                  <p class="mt-1 text-sm text-muted-foreground">
                    {essay.data.description}
                  </p>
                )}
                <div class="mt-2 flex flex-wrap gap-2 text-xs text-muted-foreground">
                  <span>
                    {essay.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                  {Array.isArray(essay.data.tags) &&
                    essay.data.tags.map((tag) => (
                      <span class="rounded-full bg-foreground/5 px-3 py-1">
                        {tag}
                      </span>
                    ))}
                </div>
                <a
                  href={`/essays/${slug}`}
                  class="mt-3 inline-flex text-xs font-semibold text-primary hover:underline"
                >
                  Read essay
                </a>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
