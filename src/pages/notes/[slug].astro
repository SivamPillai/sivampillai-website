---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import Headline from "../../components/ui/Headline.astro";
import RelatedContent from "../../components/thinking/RelatedContent.astro";

type NoteEntry = CollectionEntry<"notes">;

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => {
    const slug = note.slug ?? note.id;
    return {
      params: { slug },
      props: { note },
    };
  });
}

const { note } = Astro.props as { note: NoteEntry };
const { Content } = await render(note);

const metadata = {
  title: note.data.title,
  description: note.data.description,
};
---

<BaseLayout {metadata} section="Notes">
  <article class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-3xl">
      <Headline
        tagline="Note"
        title={note.data.title}
        subtitle={note.data.description}
        classes={{
          container: "mb-6 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "max-w-2xl text-base text-muted-foreground",
        }}
      />

      <div class="mb-4 flex flex-wrap gap-2 text-xs text-muted-foreground">
        <span>
          {note.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })}
        </span>
        {Array.isArray(note.data.tags) &&
          note.data.tags.map((tag) => (
            <span class="rounded-full bg-foreground/5 px-3 py-1">
              {tag}
            </span>
          ))}
      </div>

      <div class="prose prose-invert max-w-none text-sm leading-relaxed">
        <Content />
      </div>

      <RelatedContent currentId={note.id} tags={note.data.tags} />
    </div>
  </article>
</BaseLayout>

