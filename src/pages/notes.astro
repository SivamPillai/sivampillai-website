---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Headline from "../components/ui/Headline.astro";

const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const metadata = {
  title: "Notes",
  description:
    "Short, rough, and often incomplete notes — things I’m noticing in data, factories, or my own process.",
};
---

<BaseLayout {metadata} section="Notes">
  <section class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-5xl">
      <Headline
        tagline="Notes"
        title="Scratchpad for observations"
        subtitle="These are closer to working notes than polished essays. Expect half-finished thoughts and things I may change my mind about."
        classes={{
          container: "mb-10 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "max-w-3xl text-base text-muted-foreground",
        }}
      />

      <div class="space-y-6">
        {
          notes.map((note) => {
            const slug =
              (note as { id: string; slug?: string }).slug ?? note.id;
            return (
              <article class="reveal rounded-2xl border border-border bg-card/60 p-5 hover:border-primary/50 transition-colors">
                <h2 class="text-lg font-semibold text-foreground">
                  {note.data.title}
                </h2>
                {note.data.description && (
                  <p class="mt-1 text-sm text-muted-foreground">
                    {note.data.description}
                  </p>
                )}
                <div class="mt-2 flex flex-wrap gap-2 text-xs text-muted-foreground">
                  <span>
                    {note.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                  {Array.isArray(note.data.tags) &&
                    note.data.tags.map((tag) => (
                      <span class="rounded-full bg-foreground/5 px-3 py-1">
                        {tag}
                      </span>
                    ))}
                </div>
                <a
                  href={`/notes/${slug}`}
                  class="mt-3 inline-flex text-xs font-semibold text-primary hover:underline"
                >
                  Open note
                </a>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>
</BaseLayout>
