---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import Headline from "../components/ui/Headline.astro";

const PER_PAGE = 10;

function getQuoteDisplayId(entryId: string, quoteId?: string): string {
  if (quoteId) return quoteId;
  const match = entryId.match(/^q(\d+)/i);
  return match ? `Q${match[1].padStart(4, "0")}` : entryId;
}

const quotes = await getCollection("quotes");
const quotesWithContent = await Promise.all(
  quotes.map(async (item) => ({ item, ...(await render(item)) }))
);

const metadata = {
  title: "Quotes",
  description:
    "Lines that I keep coming back to — for design, systems thinking, and how people change.",
};
---

<BaseLayout {metadata} section="Quotes">
  <section class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-4xl">
      <Headline
        tagline="Quotes"
        title="Lines worth keeping"
        subtitle="A small, rotating collection of quotes that shape how I think about work, systems, and craft."
        classes={{
          container: "mb-10 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "max-w-2xl text-base text-muted-foreground",
        }}
      />

      <div id="quotes-list" class="space-y-6">
        {
          quotesWithContent.map(({ item, Content }, index) => {
            const displayId = getQuoteDisplayId(item.id, item.data.quoteId);
            const isLazy = index >= PER_PAGE;
            return (
            <details
              class:list={["group reveal rounded-2xl border border-border bg-card/60 overflow-hidden", isLazy && "quote-lazy-hidden"]}
              data-quote-index={index}
            >
              <summary class="relative cursor-pointer list-none p-5 pr-16 focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 [&::-webkit-details-marker]:hidden">
                <span class="absolute top-4 right-4 shrink-0 rounded-full bg-muted px-2.5 py-1 text-[11px] font-medium tabular-nums text-muted-foreground">
                  {displayId}
                </span>
                <span class="flex items-start gap-3">
                  <span
                    class="mt-0.5 shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180"
                    aria-hidden="true"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </span>
                  <span class="min-w-0 flex-1">
                    <figure>
              <blockquote class="text-sm italic text-foreground">
                “{item.data.quote}”
              </blockquote>
              <figcaption class="mt-2 text-xs text-muted-foreground">
                {item.data.sourceUrl && item.data.source ? (
                  <a
                    href={item.data.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary hover:underline"
                          >
                    — {item.data.source}
                  </a>
                ) : item.data.source ? (
                  <>— {item.data.source}</>
                ) : null}
              </figcaption>
              {item.data.description && (
                <p class="mt-3 text-xs text-muted-foreground">
                  {item.data.description}
                </p>
              )}
              <div class="mt-3 flex flex-wrap gap-2 text-[11px] text-muted-foreground">
                {Array.isArray(item.data.tags) &&
                  item.data.tags.map((tag) => (
                    <span class="rounded-full bg-foreground/5 px-3 py-1">
                      {tag}
                    </span>
                  ))}
              </div>
                    </figure>
                  </span>
                </span>
              </summary>
              <div class="border-t border-border px-5 pb-5 pt-4">
                <div class="prose prose-sm dark:prose-invert max-w-none prose-p:text-muted-foreground prose-p:leading-relaxed">
                  <Content />
                </div>
              </div>
            </details>
            );
          })
        }
      </div>

      <div
        id="quotes-sentinel"
        class="min-h-[1px] w-full"
        aria-hidden="true"
      />

      <style>
        .quote-lazy-hidden {
          display: none;
        }
      </style>
    </div>
  </section>

  <script>
    const PER_PAGE = 10;

    document.querySelectorAll("details summary a[href]").forEach((a) => {
      a.addEventListener("click", (e) => e.stopPropagation());
    });

    const list = document.getElementById("quotes-list");
    const sentinel = document.getElementById("quotes-sentinel");
    if (list && sentinel) {
      const hidden = () =>
        Array.from(list.querySelectorAll(".quote-lazy-hidden"));
      const observer = new IntersectionObserver(
        (entries) => {
          if (!entries[0]?.isIntersecting) return;
          const toReveal = hidden().slice(0, PER_PAGE);
          toReveal.forEach((el) => el.classList.remove("quote-lazy-hidden"));
          if (hidden().length === 0) sentinel.style.display = "none";
        },
        { rootMargin: "100px" }
      );
      observer.observe(sentinel);
      if (hidden().length === 0) sentinel.style.display = "none";
    }
  </script>
</BaseLayout>
