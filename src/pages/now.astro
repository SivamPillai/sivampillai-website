---
import BaseLayout from "../layouts/BaseLayout.astro";
import Headline from "../components/ui/Headline.astro";

const metadata = {
  title: "Now",
  description:
    "What I’m focused on right now — work, learning, reading, and small creative experiments.",
};
---

<BaseLayout {metadata}>
  <section class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-3xl space-y-8">
      <Headline
        tagline="Now"
        title="What I’m working on now"
        subtitle="Inspired by the /now page idea from Derek Sivers. I’ll try to keep this updated every month or two."
        classes={{
          container: "mb-4 text-left",
          title:
            "font-heading mb-3 text-3xl font-bold tracking-tight text-foreground md:text-4xl",
          subtitle: "text-sm text-muted-foreground",
        }}
      />

      <p class="text-xs text-muted-foreground">
        Last updated: March 2026
      </p>

      <div class="space-y-6 text-sm leading-relaxed text-foreground">
        <div>
          <h2 class="text-base font-semibold">Work</h2>
          <p class="mt-1 text-muted-foreground">
            Building and refining AI systems for industrial monitoring and energy
            efficiency — especially around how operators actually interact with
            models in the control room.
          </p>
        </div>

        <div>
          <h2 class="text-base font-semibold">Learning</h2>
          <p class="mt-1 text-muted-foreground">
            Exploring time-series ML architectures, physics-informed models, and
            better ways to blend domain intuition with data-driven methods.
          </p>
        </div>

        <div>
          <h2 class="text-base font-semibold">Reading</h2>
          <p class="mt-1 text-muted-foreground">
            A mix of systems thinking, industrial automation, and books that
            have nothing to do with work but quietly change how I see it.
          </p>
        </div>

        <div>
          <h2 class="text-base font-semibold">Creative</h2>
          <p class="mt-1 text-muted-foreground">
            Playing with short poems, slide design experiments, and sketches for
            how to visually explain invisible things like energy flows and
            machine states.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

