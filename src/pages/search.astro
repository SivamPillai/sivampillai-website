---
import BaseLayout from "../layouts/BaseLayout.astro";
import Headline from "../components/ui/Headline.astro";

const metadata = {
  title: "Search",
  description:
    "Search across essays, blog, projects, notes, quotes, and creatives.",
};
---

<BaseLayout {metadata}>
  <section class="px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-3xl">
      <Headline
        tagline="Search"
        title="Search the site"
        subtitle="Find essays, blog posts, projects, notes, quotes, and creatives. Use the filter below to limit by section."
        classes={{
          container: "mb-6 text-left",
          title:
            "font-heading mb-2 text-2xl font-bold tracking-tight text-foreground md:text-3xl",
          subtitle: "text-sm text-muted-foreground",
        }}
      />

      <div class="mb-6 flex flex-wrap items-center gap-3">
        <label
          for="search-section"
          class="text-sm font-medium text-muted-foreground"
        >
          Section
        </label>
        <select
          id="search-section"
          class="rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        >
          <option value="">All sections</option>
          <option value="Blog">Blog</option>
          <option value="Essays">Essays</option>
          <option value="Projects">Projects</option>
          <option value="Notes">Notes</option>
          <option value="Quotes">Quotes</option>
          <option value="Writing">Writing</option>
          <option value="Creatives">Creatives</option>
          <option value="Poetry">Poetry</option>
          <option value="Photography">Photography</option>
          <option value="Design">Design</option>
        </select>
      </div>

      <div id="search" class="min-h-[200px]"></div>
    </div>
  </section>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener("DOMContentLoaded", function () {
      if (typeof PagefindUI !== "undefined") {
        const search = new PagefindUI({
          element: "#search",
          showSubResults: true,
        });
        const select = document.getElementById("search-section");
        if (select) {
          select.addEventListener("change", function () {
            const value = select.value;
            if (value) {
              search.triggerFilters({ Section: [value] });
            } else {
              search.triggerFilters({});
            }
          });
        }
      }
    });
  </script>
</BaseLayout>
