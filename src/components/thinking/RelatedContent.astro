---
import { getCollection, type CollectionEntry } from "astro:content";
import Headline from "../ui/Headline.astro";

interface Props {
  currentId: string;
  tags: string[];
}

const { currentId, tags } = Astro.props as Props;

const allCollections = [
  "projects",
  "essays",
  "notes",
  "quotes",
  "blog",
] as const;
type CollectionName = (typeof allCollections)[number];

type AnyEntry =
  | CollectionEntry<"projects">
  | CollectionEntry<"essays">
  | CollectionEntry<"notes">
  | CollectionEntry<"quotes">
  | CollectionEntry<"blog">;

async function getRelated() {
  if (!tags || tags.length === 0) return {};

  const results: Record<string, AnyEntry[]> = {};

  for (const name of allCollections) {
    const entries = (await getCollection(name as CollectionName)) as AnyEntry[];
    const related = entries
      .filter((entry: AnyEntry) => entry.id !== currentId)
      .filter((entry: AnyEntry) => {
        const entryTags = (entry.data as { tags?: string[] }).tags ?? [];
        return entryTags.some((tag: string) => tags.includes(tag));
      })
      .slice(0, 3);

    if (related.length > 0) {
      results[name] = related;
    }
  }

  return results;
}

const related = await getRelated();
const hasAny =
  Object.keys(related).length > 0 &&
  Object.values(related).some((list) => list && list.length > 0);
---

{
  hasAny && (
    <section class="mt-16 border-t border-border pt-10">
      <Headline
        title="Related from the thinking lab"
        subtitle="Other things connected by tags — essays, projects, quotes, and notes."
        classes={{
          container: "mb-8",
          title:
            "text-2xl md:text-3xl font-semibold tracking-tight text-foreground",
          subtitle: "text-sm text-muted-foreground max-w-xl",
        }}
      />

      <div class="grid gap-8 md:grid-cols-3">
        {Object.entries(related).map(([key, entries]) => (
          <div>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-muted-foreground">
              {key === "projects"
                ? "Related Projects"
                : key === "essays"
                  ? "Related Essays"
                  : key === "notes"
                    ? "Related Notes"
                    : key === "quotes"
                      ? "Related Quotes"
                      : "Related Blog"}
            </h3>
            <ul class="space-y-2 text-sm">
              {entries.map((entry) => {
                const slug =
                  (entry as AnyEntry & { slug?: string }).slug ?? entry.id;
                const base =
                  key === "blog"
                    ? "/blog"
                    : key === "projects"
                      ? "/projects"
                      : key === "essays"
                        ? "/essays"
                        : key === "notes"
                          ? "/notes"
                          : key === "quotes"
                            ? "/quotes"
                            : `/${key}`;
                const href = slug ? `${base}/${slug}` : base;
                return (
                  <li>
                    <a
                      href={href}
                      class="text-foreground hover:text-primary underline-offset-2 hover:underline"
                    >
                      {(entry.data as { title?: string }).title ?? entry.id}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )
}
