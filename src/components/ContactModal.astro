---
import { siteConfig } from "../config/site";

const formAction = `https://formspree.io/f/${siteConfig.formspreeFormId}`;
---

<dialog
  id="contact-modal"
  class="fixed inset-0 z-[100] max-h-[100vh] w-full max-w-none border-0 bg-black/50 p-0 backdrop:bg-black/50 [&::backdrop]:bg-black/50"
  aria-modal="true"
  aria-labelledby="contact-modal-title"
>
  <div class="flex min-h-full items-center justify-center p-4">
    <div
      class="relative w-full max-w-md rounded-2xl border border-border bg-background p-6 shadow-xl"
      id="contact-modal-inner"
    >
      <button
        type="button"
        class="contact-modal-close absolute right-4 top-4 rounded-full p-2 text-muted-foreground hover:bg-muted hover:text-foreground"
        aria-label="Close contact form"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <h2
        id="contact-modal-title"
        class="text-xl font-semibold text-foreground pr-10"
      >
        Contact
      </h2>
      <p class="mt-1 text-sm text-muted-foreground">
        Reach me at
        <a
          href={`mailto:${siteConfig.contactEmail}`}
          class="text-primary hover:underline"
        >
          {siteConfig.contactEmail}
        </a>
        or use the form below.
      </p>

      <form action={formAction} method="POST" class="mt-6 space-y-4">
        <input
          type="hidden"
          name="_subject"
          value="Contact form submission from sivampillai.com"
        />
        <input
          type="text"
          name="_gotcha"
          class="hidden"
          tabindex="-1"
          autocomplete="off"
        />
        <div>
          <label
            for="contact-name"
            class="block text-sm font-medium text-foreground mb-1.5"
          >
            Name
          </label>
          <input
            type="text"
            name="name"
            id="contact-name"
            autocomplete="name"
            required
            class="block w-full rounded-lg border border-border bg-muted/50 px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="Your name"
          />
        </div>
        <div>
          <label
            for="contact-email"
            class="block text-sm font-medium text-foreground mb-1.5"
          >
            Your email
          </label>
          <input
            type="email"
            name="email"
            id="contact-email"
            autocomplete="email"
            required
            class="block w-full rounded-lg border border-border bg-muted/50 px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label
            for="contact-message"
            class="block text-sm font-medium text-foreground mb-1.5"
          >
            Message
          </label>
          <textarea
            name="message"
            id="contact-message"
            rows="4"
            required
            class="block w-full rounded-lg border border-border bg-muted/50 px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-none"
            placeholder="Your message"></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-white hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          Send message
        </button>
      </form>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.getElementById("contact-modal") as HTMLDialogElement;
  const closeBtn = document.querySelector(".contact-modal-close");
  const inner = document.getElementById("contact-modal-inner");

  function closeModal() {
    dialog?.close();
  }

  inner?.addEventListener("click", (e) => e.stopPropagation());

  document.querySelectorAll("[data-open-contact-modal]").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.preventDefault();
      dialog?.showModal();
    });
  });

  closeBtn?.addEventListener("click", closeModal);
  dialog?.addEventListener("click", (e) => {
    if (e.target === dialog) closeModal();
  });
  dialog?.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
