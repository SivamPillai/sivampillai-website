---
import { siteConfig } from "../../config/site";
import ThemeToggle from "../ui/ThemeToggle.astro";
---

<nav
  class="fixed top-0 z-50 w-full border-b border-border bg-background md:bg-background/50 md:backdrop-blur"
>
  <div
    class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
  >
    <div class="flex items-center gap-2">
      <a
        href="/"
        class="text-xl font-bold tracking-tight text-foreground transition-colors hover:text-primary"
      >
        {siteConfig.name}
      </a>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden md:block">
      <div class="ml-10 flex items-baseline space-x-8">
        {
          siteConfig.navLinks.map((link) => {
            if (link.text === "Writing") {
              return (
                <div class="relative group">
                  <a
                    href={link.href}
                    class="text-sm font-medium text-foreground transition-colors hover:text-primary"
                  >
                    Writing
                  </a>
                  <div class="pointer-events-none absolute left-0 top-full w-40 rounded-md border border-border bg-background pt-2 pb-2 text-sm shadow-lg opacity-0 translate-y-0 transition-all duration-150 group-hover:opacity-100 group-hover:pointer-events-auto">
                    <a
                      href="/essays"
                      class="block px-3 py-1.5 text-foreground hover:text-primary hover:bg-foreground/5"
                    >
                      Essays
                    </a>
                    <a
                      href="/blog"
                      class="block px-3 py-1.5 text-foreground hover:text-primary hover:bg-foreground/5"
                    >
                      Blog
                    </a>
                    <a
                      href="/quotes"
                      class="block px-3 py-1.5 text-foreground hover:text-primary hover:bg-foreground/5"
                    >
                      Quotes
                    </a>
                    <a
                      href="/notes"
                      class="block px-3 py-1.5 text-foreground hover:text-primary hover:bg-foreground/5"
                    >
                      Notes
                    </a>
                  </div>
                </div>
              );
            }

            if (link.text === "Creatives") {
              return (
                <div class="relative group">
                  <a
                    href={link.href}
                    class="text-sm font-medium text-foreground transition-colors hover:text-primary"
                  >
                    Creatives
                  </a>
                  <div class="pointer-events-none absolute left-0 top-full w-44 rounded-md border border-border bg-background pt-2 pb-2 text-sm shadow-lg opacity-0 translate-y-0 transition-all duration-150 group-hover:opacity-100 group-hover:pointer-events-auto">
                    <a
                      href="/creatives/design"
                      class="block px-3 py-1.5 text-foreground hover:text-primary hover:bg-foreground/5"
                    >
                      Design
                    </a>
                    <a
                      href="/creatives/poetry"
                      class="block px-3 py-1.5 text-foreground hover:text-primary hover:bg-foreground/5"
                    >
                      Poetry
                    </a>
                    <a
                      href="/creatives/photography"
                      class="block px-3 py-1.5 text-foreground hover:text-primary hover:bg-foreground/5"
                    >
                      Photography
                    </a>
                  </div>
                </div>
              );
            }

            return (
              <a
                href={link.href}
                class="text-sm font-medium text-foreground transition-colors hover:text-primary"
              >
                {link.text}
              </a>
            );
          })
        }
      </div>
    </div>

    <div class="hidden md:flex items-center gap-4">
      <a
        href={siteConfig.socialLinks.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-foreground/10 px-4 py-2 text-sm font-semibold text-foreground transition-all hover:bg-foreground/20"
      >
        LinkedIn
      </a>
      <ThemeToggle />
    </div>

    <!-- Mobile Menu Button -->
    <div class="md:hidden flex items-center">
      <button
        id="mobile-menu-button"
        type="button"
        class="inline-flex items-center justify-center p-2 rounded-md text-foreground hover:text-white hover:bg-white/10 focus:outline-none transition-colors"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="sr-only">Open main menu</span>
        <!-- Icon when menu is closed -->
        <svg
          id="menu-icon-closed"
          class="block h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <!-- Icon when menu is open -->
        <svg
          id="menu-icon-open"
          class="hidden h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <div class="ml-2">
        <ThemeToggle />
      </div>
    </div>
  </div>

  <div class="hidden md:hidden" id="mobile-menu">
    <div
      class="space-y-1 border-b border-border bg-background/90 px-2 pb-3 pt-2 sm:px-3"
    >
      <a
        href="/"
        class="block rounded-md px-3 py-2 text-base font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
      >
        Home
      </a>
      <a
        href="/projects"
        class="block rounded-md px-3 py-2 text-base font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
      >
        Projects
      </a>
      <div class="pt-1">
        <p
          class="px-3 pb-1 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Writing
        </p>
        <a
          href="/essays"
          class="block rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
        >
          Essays
        </a>
        <a
          href="/blog"
          class="block rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
        >
          Blog
        </a>
        <a
          href="/quotes"
          class="block rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
        >
          Quotes
        </a>
        <a
          href="/notes"
          class="block rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
        >
          Notes
        </a>
      </div>

      <div class="pt-2">
        <p
          class="px-3 pb-1 text-xs font-semibold uppercase tracking-wide text-muted-foreground"
        >
          Creatives
        </p>
        <a
          href="/creatives/design"
          class="block rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
        >
          Design
        </a>
        <a
          href="/creatives/poetry"
          class="block rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
        >
          Poetry
        </a>
        <a
          href="/creatives/photography"
          class="block rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
        >
          Photography
        </a>
      </div>

      <a
        href="/about"
        class="block rounded-md px-3 py-2 text-base font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
      >
        About
      </a>
      <a
        href="/now"
        class="block rounded-md px-3 py-2 text-base font-medium text-foreground transition-colors hover:bg-white/10 hover:text-primary"
      >
        Now
      </a>
      <a
        href={siteConfig.socialLinks.github}
        target="_blank"
        class="block rounded-md px-3 py-2 text-base font-medium text-blue-400 transition-colors hover:cursor-pointer hover:bg-blue-500/10 hover:text-blue-300"
        >GitHub</a
      >
    </div>
  </div>
</nav>

<script>
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");
  const iconClosed = document.getElementById("menu-icon-closed");
  const iconOpen = document.getElementById("menu-icon-open");

  button?.addEventListener("click", () => {
    const isExpanded = button.getAttribute("aria-expanded") === "true";

    button.setAttribute("aria-expanded", String(!isExpanded));
    menu?.classList.toggle("hidden");
    iconClosed?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
  });
</script>
