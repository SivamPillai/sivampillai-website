---
import { siteConfig } from "../../config/site";
import ContactModal from "../ContactModal.astro";
---

<footer class="mt-20 border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="flex flex-col items-center gap-2 md:items-start">
        <span class="text-lg font-bold text-foreground">{siteConfig.name}</span>
        <p class="text-sm text-muted-foreground">
          {siteConfig.description}
        </p>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">
          Explore
        </h3>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <li>
            <a href="/projects" class="hover:text-primary">Projects</a>
          </li>
          <li>
            <a href="/essays" class="hover:text-primary">Essays</a>
          </li>
          <li>
            <a href="/blog" class="hover:text-primary">Blog</a>
          </li>
          <li>
            <a href="/notes" class="hover:text-primary">Notes</a>
          </li>
          <li>
            <a href="/creatives" class="hover:text-primary">Creatives</a>
          </li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">
          Pages
        </h3>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <li>
            <a href="/about" class="hover:text-primary">About</a>
          </li>
          <li>
            <a href="/now" class="hover:text-primary">Now</a>
          </li>
          <li>
            <a href="/resources" class="hover:text-primary">Resources</a>
          </li>
          <li>
            <a href="/search" class="hover:text-primary">Search</a>
          </li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">
          Connect
        </h3>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <li>
            <a
              href="#"
              data-open-contact-modal
              class="hover:text-primary cursor-pointer"
              >Contact</a
            >
          </li>
          <li>
            <a
              href={siteConfig.socialLinks.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary"
              >LinkedIn</a
            >
          </li>
          <li>
            <a
              href={siteConfig.socialLinks.x}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary"
              >X</a
            >
          </li>
          <li>
            <a
              href={siteConfig.socialLinks.github}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary"
              >GitHub</a
            >
          </li>
          <li>
            <a
              href={siteConfig.socialLinks.medium}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary"
              >Medium</a
            >
          </li>
        </ul>
      </div>
    </div>
    <div
      class="mt-8 border-t border-border pt-8 text-center text-xs text-muted-foreground"
    >
      &copy; {new Date().getFullYear()}
      {siteConfig.author}. Code licensed under MIT • Content licensed under CC BY 4.0
    </div>
  </div>
  <ContactModal />
</footer>
