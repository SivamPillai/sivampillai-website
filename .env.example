# Copy to .env and fill in. Do not commit .env to the repo.
# See README or Formspree docs for how to get the form ID.

PUBLIC_CONTACT_EMAIL=contact@example.com
PUBLIC_FORMSPREE_FORM_ID=your_formspree_form_id

# Optional: Firebase Storage base URL for resolving image paths in content.
# If set, frontmatter "image" can be a path (e.g. public/blogs/onstage.webp) instead of a full URL.
# Format: https://firebasestorage.googleapis.com/v0/b/YOUR_PROJECT.firebasestorage.app/o
PUBLIC_STORAGE_BASE_URL=https://firebasestorage.googleapis.com/v0/b/your-project.firebasestorage.app/o
